\ls1\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\fs26 Backend: Node.js, Express, Prisma ORM\
\ls1\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\fs26 Database: PostgreSQL via Supabase\
\ls1\ilvl0
